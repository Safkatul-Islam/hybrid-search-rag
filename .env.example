# Copy to .env and fill in values. .env is gitignored and must never be committed.

# --- Ingestion / chunking (used now, Batch 1) ---
CHUNK_SIZE=1000
CHUNK_OVERLAP=200

# --- Storage (used now, Batch 1) ---
SQLITE_PATH=./data/chunks.sqlite

# --- Cohere: embeddings (used now, Batch 2a) ---
# Model names/dimensions must be taken from official provider docs, not invented.
COHERE_API_KEY=
COHERE_EMBED_MODEL=embed-v4.0
EMBED_DIMENSION=1024

# --- Pinecone: dense vector store (used now, Batch 2b) ---
# The index is created on first use as serverless. Its dimension must match
# EMBED_DIMENSION above. Only the API key is a secret; the rest are safe defaults.
PINECONE_API_KEY=
PINECONE_INDEX_NAME=hybrid-rag-docs
PINECONE_CLOUD=aws
PINECONE_REGION=us-east-1

# --- Providers (used in later batches; leave blank for now) ---
# Anthropic (answer generation)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=
# Cohere rerank (used now, Batch 4a) — reuses COHERE_API_KEY above.
# Leave blank to use the code default (rerank-v4.0-pro); a blank value is
# treated as "use default", not as an empty model name.
COHERE_RERANK_MODEL=rerank-v4.0-pro
